# --- Öffentlich (im Browser sichtbar, mit NEXT_PUBLIC_ prefixen) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Serverseitig (NIEMALS mit NEXT_PUBLIC_ prefixen, nie ins Repo) ---
# Service-Role-Key umgeht alle RLS-Policies – nur in Server-Code/Route-Handlern verwenden.
SUPABASE_SERVICE_KEY=

